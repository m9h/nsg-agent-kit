# Copy to nsgr/config.env and fill in. DO NOT put your password here.
# config.env is gitignored.

export NSG_URL="https://nsgr.sdsc.edu:8443/cipresrest/v1"
export NSG_USER="your_nsg_username"
export NSG_APPKEY="your_application_id"      # Portal → Developer → Application Management

# Tool id for the PyTorch GPU tool — CONFIRM on the authenticated Task page.
# (portal name: "PyTorch Python on Expanse (2.0.1+cu117)")
export NSG_TOOL="PYTORCH_EXPANSE"            # <-- verify; placeholder

# Optional tool-specific parameters, e.g. runtime hours / runfile name:
# export NSG_EXTRA='-F vparam.runtime_=0.5 -F vparam.filename_=run.py'

# Password: export interactively, never store on disk:
#   read -s NSG_PASSWORD; export NSG_PASSWORD
